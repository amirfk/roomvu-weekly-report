<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ deck_title }}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- reveal.js -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reset.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.css" />

  <!-- Chart.js for line chart slides -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

  <style>
    /* ── Brand tokens ─────────────────────────────────────────── */
    :root {
      --navy:   #001449;
      --white:  #ffffff;
      --gray50: #f8f9fa;
      --gray200:#e9ecef;
      --gray600:#6c757d;
      --font:   'Inter', system-ui, sans-serif;
    }

    /* ── Base reveal overrides ───────────────────────────────── */
    .reveal-viewport { background: var(--white); }
    .reveal          { font-family: var(--font); color: #222; }
    .reveal .slides  { text-align: left; }
    .reveal section  { padding: 0 !important; }

    /* ── Slide layout ────────────────────────────────────────── */
    .slide-wrap {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 28px 40px 20px;
      box-sizing: border-box;
    }

    /* ── Slide header bar ─────────────────────────────────────── */
    .slide-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid var(--navy);
      padding-bottom: 10px;
      margin-bottom: 18px;
      flex-shrink: 0;
    }
    .slide-header img.logo { height: 32px; object-fit: contain; }
    .slide-header .report-date { font-size: .72em; color: var(--gray600); }

    /* ── Slide title ─────────────────────────────────────────── */
    .slide-wrap h2 {
      font-size: 1.15em;
      font-weight: 700;
      color: var(--navy);
      margin: 0 0 4px;
      line-height: 1.3;
    }
    .slide-title-block { margin-bottom: 14px; }
    .slide-title-underline {
      height: 3px;
      width: 200px;
      background: linear-gradient(90deg, #E8A020 0%, #4CAF50 100%);
      border-radius: 2px;
      margin-top: 5px;
    }

    /* ── Title slide ─────────────────────────────────────────── */
    .title-slide {
      background: var(--navy);
      color: var(--white);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      height: 100%;
      padding: 40px;
      box-sizing: border-box;
      position: relative;
      overflow: hidden;
    }
    /* subtle diagonal accent */
    .title-slide::before {
      content: '';
      position: absolute;
      top: -80px; right: -80px;
      width: 340px; height: 340px;
      background: rgba(255,255,255,.04);
      border-radius: 50%;
    }
    .title-slide::after {
      content: '';
      position: absolute;
      bottom: -60px; left: -60px;
      width: 260px; height: 260px;
      background: rgba(255,255,255,.03);
      border-radius: 50%;
    }
    .title-slide img.logo {
      height: 52px;
      margin-bottom: 36px;
      filter: brightness(0) invert(1);
      position: relative; z-index: 1;
    }
    .title-slide h1 {
      font-size: 2em;
      font-weight: 700;
      color: var(--white);
      margin: 0 0 8px;
      line-height: 1.2;
      position: relative; z-index: 1;
    }
    .title-slide .week-range {
      font-size: 1.1em;
      font-weight: 600;
      color: #E8A020;
      margin: 0 0 24px;
      position: relative; z-index: 1;
      letter-spacing: .02em;
    }
    .title-slide .divider {
      width: 60px; height: 3px;
      background: linear-gradient(90deg, #E8A020, #4CAF50);
      border-radius: 2px;
      margin: 0 auto 20px;
      position: relative; z-index: 1;
    }
    .title-slide .subtitle {
      font-size: .8em;
      color: rgba(255,255,255,.5);
      position: relative; z-index: 1;
    }

    /* ── Cohort table ────────────────────────────────────────── */
    .table-scroll {
      overflow-x: auto;
      flex: 1;
    }
    table.cohort {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: .72em;
      min-width: 520px;
    }
    table.cohort thead tr {
      background: var(--navy);
      color: var(--white);
    }
    table.cohort thead th {
      padding: 9px 12px;
      font-weight: 600;
      text-align: center;
      white-space: nowrap;
      border-right: 1px solid rgba(255,255,255,.12);
      letter-spacing: .02em;
      font-size: .95em;
    }
    table.cohort thead th:first-child { border-radius: 6px 0 0 0; }
    table.cohort thead th:last-child  { border-radius: 0 6px 0 0; border-right: none; }
    table.cohort thead th.col-left { text-align: left; }

    table.cohort tbody tr:nth-child(even) { background: var(--gray50); }
    table.cohort tbody tr:hover           { background: #eef2ff; }
    table.cohort tbody td {
      padding: 8px 12px;
      border-bottom: 1px solid var(--gray200);
      border-right: 1px solid var(--gray200);
      text-align: center;
      white-space: nowrap;
      font-size: .95em;
    }
    table.cohort tbody td:last-child { border-right: none; }
    table.cohort tbody td.col-left { text-align: left; font-weight: 500; }

    /* week-cell shading applied inline via style attr */
    table.cohort tbody td.week-cell { font-weight: 600; border-radius: 4px; }
    table.cohort tbody td.week-cell.blank { background: none !important; color: inherit; }

    /* ── Skip / error notice ─────────────────────────────────── */
    .skip-notice {
      padding: 24px;
      background: var(--gray50);
      border: 1px solid var(--gray200);
      border-radius: 6px;
      color: var(--gray600);
      font-size: .85em;
    }

    /* ── Print button ───────────────────────────────────────── */
    #print-btn {
      position: fixed;
      top: 14px;
      right: 18px;
      z-index: 9999;
      background: var(--navy);
      color: var(--white);
      border: none;
      border-radius: 6px;
      padding: 7px 16px;
      font-family: var(--font);
      font-size: .78em;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: .03em;
      opacity: .85;
      transition: opacity .15s;
    }
    #print-btn:hover { opacity: 1; }
    @media print { #print-btn { display: none; } }

    /* ── Meta KPI slide ─────────────────────────────────────── */
    .kpi-wrap {
      display: flex;
      gap: 40px;
      align-items: flex-start;
      flex: 1;
    }
    .kpi-left {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 18px;
      justify-content: center;
    }
    .kpi-row {
      display: flex;
      align-items: baseline;
      gap: 12px;
      border-bottom: 1px solid var(--gray200);
      padding-bottom: 14px;
    }
    .kpi-row:last-child { border-bottom: none; padding-bottom: 0; }
    .kpi-label {
      font-size: .85em;
      color: var(--gray600);
      min-width: 140px;
      font-weight: 500;
    }
    .kpi-value {
      font-size: 1.6em;
      font-weight: 700;
      color: var(--navy);
    }
    .kpi-creative {
      width: 280px;
      flex-shrink: 0;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid var(--gray200);
      background: var(--gray50);
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 260px;
    }
    .kpi-creative img { width: 100%; height: auto; display: block; }
    .kpi-creative .no-creative {
      color: var(--gray600);
      font-size: .8em;
      padding: 20px;
      text-align: center;
    }
    .platform-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: .78em;
      font-weight: 700;
      color: #1877F2;
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }

    /* ── Chart slides ───────────────────────────────────────── */
    .charts-wrap {
      display: flex;
      gap: 16px;
      width: 100%;
      margin-top: 8px;
    }
    .chart-panel {
      flex: 1;
      min-width: 0;
    }
    .chart-label {
      text-align: center;
      font-size: .75em;
      color: #888;
      margin: 0 0 6px;
      font-weight: 500;
    }
    .chart-panel {
      position: relative;
      height: 360px;
    }
    .chart-panel canvas {
      position: absolute;
      top: 0; left: 0;
      width: 100% !important;
      height: 100% !important;
    }

    /* ── Region table slide ─────────────────────────────────── */
    .region-tables { display: flex; flex-direction: column; gap: 14px; flex: 1; overflow: auto; }
    .region-period-label {
      font-size: .75em;
      font-weight: 700;
      color: var(--gray600);
      text-transform: uppercase;
      letter-spacing: .05em;
      margin-bottom: 4px;
    }
    table.region {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: .7em;
      min-width: 560px;
    }
    table.region thead tr { background: var(--navy); color: var(--white); }
    table.region thead th {
      padding: 7px 10px;
      font-weight: 600;
      text-align: right;
      white-space: nowrap;
      border-right: 1px solid rgba(255,255,255,.12);
      font-size: .93em;
    }
    table.region thead th:first-child { text-align: left; border-radius: 5px 0 0 0; }
    table.region thead th:last-child  { border-right: none; border-radius: 0 5px 0 0; }
    table.region tbody tr:nth-child(even) { background: var(--gray50); }
    table.region tbody td {
      padding: 6px 10px;
      border-bottom: 1px solid var(--gray200);
      border-right: 1px solid var(--gray200);
      text-align: right;
      white-space: nowrap;
    }
    table.region tbody td:first-child { text-align: left; font-weight: 500; }
    table.region tbody td:last-child  { border-right: none; }
    table.region td.dash { color: var(--gray600); }

    /* ── Print / PDF ─────────────────────────────────────────── */
    @media print {
      .reveal .slides { font-size: 11pt; }
      table.cohort { font-size: 8pt; }
      .slide-wrap { padding: 16px 24px 12px; }
      .table-scroll { overflow: visible; }
      /* Prevent table rows from splitting across pages */
      table.cohort tbody tr { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
<div class="reveal">
  <div class="slides">

    <!-- ── Title slide ──────────────────────────────────────── -->
    <section>
      <div class="title-slide">
        <img class="logo" src="{{ logo_url }}" alt="Roomvu" />
        <h1>Acquisition Report</h1>
        <p class="week-range">{{ week_label }}</p>
        <div class="divider"></div>
        <p class="subtitle">Generated {{ generated }}</p>
      </div>
    </section>

    <!-- ── Data slides ──────────────────────────────────────── -->
    {% for slide in slides %}
    <section>
      <div class="slide-wrap">
        <div class="slide-header">
          <img class="logo" src="{{ logo_url }}" alt="Roomvu" />
          <span class="report-date">{{ generated }}</span>
        </div>
        <div class="slide-title-block">
          {% if slide.platform == 'meta' %}
          <div class="platform-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.269h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
            Meta
          </div>
          {% endif %}
          <h2>{{ slide.title }}</h2>
          <div class="slide-title-underline"></div>
        </div>

        {% if slide.skipped %}
        <div class="skip-notice">
          {% if slide.error is defined %}
            Data unavailable: {{ slide.error }}
          {% else %}
            Question ID not configured — add the Metabase question ID to config.yaml.
          {% endif %}
        </div>

        {% elif slide.render == 'cohort_table' %}
        <div class="table-scroll">
          <table class="cohort">
            <thead>
              <tr>
                <th class="col-left">Week</th>
                <th>Registrations</th>
                <th>Amount Spent</th>
                {% for wc in slide.week_cols %}
                <th>{{ wc }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in slide.rows %}
              <tr>
                <td class="col-left">{{ row.week }}</td>
                <td>{{ row.Registration }}</td>
                <td>${{ row.Amount_Spent_display }}</td>
                {% for wc in slide.week_cols %}
                  {% set cell = row.week_cells[wc] %}
                  {% if cell.color %}
                  <td class="week-cell" style="{{ cell.color }}">{{ cell.text }}</td>
                  {% else %}
                  <td class="week-cell blank"></td>
                  {% endif %}
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>

        {% elif slide.render == 'meta_kpi' %}
        <div class="kpi-wrap">
          <div class="kpi-left">
            {% for kpi in slide.kpis %}
            <div class="kpi-row">
              <span class="kpi-label">{{ kpi.label }}:</span>
              <span class="kpi-value">{{ kpi.value }}</span>
            </div>
            {% endfor %}
          </div>
          <div class="kpi-creative">
            {% if slide.creative_url %}
            <img src="{{ slide.creative_url }}" alt="Ad creative" />
            {% else %}
            <span class="no-creative">No creative configured</span>
            {% endif %}
          </div>
        </div>

        {% elif slide.render in ('dual_line_chart', 'line_chart') %}
        <div class="charts-wrap charts-{{ slide.charts | length }}">
          {% for chart in slide.charts %}
          <div class="chart-panel">
            <p class="chart-label">{{ chart.label }}</p>
            {% if chart.error is defined %}
            <div class="skip-notice">{{ chart.error }}</div>
            {% else %}
            <canvas id="chart-{{ slide.id | default(loop.index0) }}-{{ loop.index0 }}"></canvas>
            <script>
            (function(){
              var labels = {{ chart['labels'] | tojson }};
              var values = {{ chart['data'] | tojson }};
              var fmt   = {{ chart.format | tojson }};
              var color = {{ chart.color | tojson }};
              var ctx = document.getElementById('chart-{{ slide.id | default(loop.index0) }}-{{ loop.index0 }}');
              new Chart(ctx, {
                type: 'line',
                data: {
                  labels: labels,
                  datasets: [{
                    data: values,
                    borderColor: color,
                    backgroundColor: color + '22',
                    pointBackgroundColor: color,
                    pointRadius: 3,
                    pointHoverRadius: 5,
                    borderWidth: 2,
                    tension: 0.1,
                    fill: false,
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  animation: false,
                  plugins: {
                    legend: { display: false },
                    tooltip: {
                      callbacks: {
                        label: function(ctx) {
                          var v = ctx.parsed.y;
                          if (fmt === 'currency') return '$' + v.toLocaleString('en-US', {minimumFractionDigits:0, maximumFractionDigits:0});
                          if (fmt === 'percent') return v.toFixed(1) + '%';
                          return v.toLocaleString('en-US');
                        }
                      }
                    },
                    datalabels: { display: false }
                  },
                  scales: {
                    x: {
                      ticks: {
                        font: { size: 9, family: 'Inter' },
                        maxRotation: 45,
                        autoSkip: true,
                        maxTicksLimit: 20,
                      },
                      grid: { color: '#eee' }
                    },
                    y: {
                      ticks: {
                        font: { size: 9, family: 'Inter' },
                        callback: function(v) {
                          if (fmt === 'currency') return '$' + v.toLocaleString('en-US');
                          if (fmt === 'percent') return v + '%';
                          return v.toLocaleString('en-US');
                        }
                      },
                      grid: { color: '#eee' }
                    }
                  }
                }
              });
            })();
            </script>
            {% endif %}
          </div>
          {% endfor %}
        </div>

        {% elif slide.render == 'region_table' %}
        {%- macro region_rows(rows) %}
          {% for row in rows %}
          <tr>
            <td>{{ row.targeting }}</td>
            <td>${{ "{:,.0f}".format(row.spend | float) }}</td>
            <td>{{ row.registrations }}</td>
            <td>{% if row.cpa is not none %}${{ "{:.1f}".format(row.cpa | float) }}{% else %}<span class="dash">—</span>{% endif %}</td>
            <td>{{ row.subs }}</td>
            <td>{{ row.tot_subs }}</td>
            <td>{% if row.imm_rev and row.imm_rev | float > 0 %}<strong>${{ "{:,.0f}".format(row.imm_rev | float) }}</strong>{% else %}<span class="dash">—</span>{% endif %}</td>
            <td>{% if row.imm_rev_rate is not none and row.imm_rev_rate | float > 0 %}{{ "{:.0f}".format(row.imm_rev_rate | float) }}%{% else %}<span class="dash">—</span>{% endif %}</td>
          </tr>
          {% endfor %}
        {%- endmacro %}
        <div class="region-tables">
          {% for period_label, rows in [(slide.this_week_label, slide.this_week_rows), (slide.last_week_label, slide.last_week_rows)] %}
          <div>
            <p class="region-period-label">{{ period_label }}</p>
            <div style="overflow-x:auto">
              <table class="region">
                <thead>
                  <tr>
                    <th>Targeting</th>
                    <th>Spend</th>
                    <th>Registrations</th>
                    <th>CPA</th>
                    <th>Subs.</th>
                    <th>Tot. subs</th>
                    <th>Imm Rev</th>
                    <th>Imm Rev Rate</th>
                  </tr>
                </thead>
                <tbody>{{ region_rows(rows) }}</tbody>
              </table>
            </div>
          </div>
          {% endfor %}
        </div>

        {% endif %}

      </div>
    </section>
    {% endfor %}

  </div><!-- /.slides -->
</div><!-- /.reveal -->

<button id="print-btn" onclick="window.location.href=window.location.pathname+'?print-pdf#/'">⬇ Export PDF</button>

<script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.js"></script>
<script>
  const isPrintMode = window.location.search.includes('print-pdf');
  if (isPrintMode) {
    document.getElementById('print-btn').style.display = 'none';
  }

  Reveal.initialize({
    hash: true,
    center: false,
    margin: 0.04,
    width: 1280,
    height: 720,
    transition: 'slide',
    transitionSpeed: 'fast',
    pdfMaxPagesPerSlide: 1,
    pdfSeparateFragments: false,
  });

  // Auto-trigger print dialog when loaded in ?print-pdf mode
  if (isPrintMode) {
    Reveal.addEventListener('ready', function() {
      setTimeout(function() { window.print(); }, 1000);
    });
  }
</script>
</body>
</html>
