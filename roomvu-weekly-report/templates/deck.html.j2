<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ deck_title }}</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- reveal.js -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reset.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.css" />

  <style>
    /* ── Brand tokens ─────────────────────────────────────────── */
    :root {
      --navy:   #001449;
      --white:  #ffffff;
      --gray50: #f8f9fa;
      --gray200:#e9ecef;
      --gray600:#6c757d;
      --font:   'Inter', system-ui, sans-serif;
    }

    /* ── Base reveal overrides ───────────────────────────────── */
    .reveal-viewport { background: var(--white); }
    .reveal          { font-family: var(--font); color: #222; }
    .reveal .slides  { text-align: left; }
    .reveal section  { padding: 0 !important; }

    /* ── Slide layout ────────────────────────────────────────── */
    .slide-wrap {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 28px 40px 20px;
      box-sizing: border-box;
    }

    /* ── Slide header bar ─────────────────────────────────────── */
    .slide-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid var(--navy);
      padding-bottom: 10px;
      margin-bottom: 18px;
      flex-shrink: 0;
    }
    .slide-header img.logo { height: 32px; object-fit: contain; }
    .slide-header .report-date { font-size: .72em; color: var(--gray600); }

    /* ── Slide title ─────────────────────────────────────────── */
    .slide-wrap h2 {
      font-size: 1.15em;
      font-weight: 700;
      color: var(--navy);
      margin: 0 0 14px;
      line-height: 1.3;
    }

    /* ── Title slide ─────────────────────────────────────────── */
    .title-slide {
      background: var(--navy);
      color: var(--white);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      height: 100%;
      padding: 40px;
      box-sizing: border-box;
    }
    .title-slide img.logo { height: 56px; margin-bottom: 32px; filter: brightness(0) invert(1); }
    .title-slide h1 { font-size: 1.7em; font-weight: 700; color: var(--white); margin: 0 0 16px; }
    .title-slide .subtitle { font-size: .9em; color: rgba(255,255,255,.75); }

    /* ── Cohort table ────────────────────────────────────────── */
    .table-scroll {
      overflow-x: auto;
      flex: 1;
    }
    table.cohort {
      width: 100%;
      border-collapse: collapse;
      font-size: .72em;
      min-width: 520px;
    }
    table.cohort thead tr {
      background: var(--navy);
      color: var(--white);
    }
    table.cohort thead th {
      padding: 7px 10px;
      font-weight: 600;
      text-align: center;
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,.15);
    }
    table.cohort thead th.col-left { text-align: left; }

    table.cohort tbody tr:nth-child(even) { background: var(--gray50); }
    table.cohort tbody tr:hover           { background: var(--gray200); }
    table.cohort tbody td {
      padding: 6px 10px;
      border: 1px solid var(--gray200);
      text-align: center;
      white-space: nowrap;
    }
    table.cohort tbody td.col-left { text-align: left; }

    /* week-cell shading applied inline via style attr */
    table.cohort tbody td.week-cell { font-weight: 500; }
    table.cohort tbody td.week-cell.blank { background: none !important; color: inherit; }

    /* ── Skip / error notice ─────────────────────────────────── */
    .skip-notice {
      padding: 24px;
      background: var(--gray50);
      border: 1px solid var(--gray200);
      border-radius: 6px;
      color: var(--gray600);
      font-size: .85em;
    }

    /* ── Print button ───────────────────────────────────────── */
    #print-btn {
      position: fixed;
      top: 14px;
      right: 18px;
      z-index: 9999;
      background: var(--navy);
      color: var(--white);
      border: none;
      border-radius: 6px;
      padding: 7px 16px;
      font-family: var(--font);
      font-size: .78em;
      font-weight: 600;
      cursor: pointer;
      letter-spacing: .03em;
      opacity: .85;
      transition: opacity .15s;
    }
    #print-btn:hover { opacity: 1; }
    @media print { #print-btn { display: none; } }

    /* ── Print / PDF ─────────────────────────────────────────── */
    @media print {
      .reveal .slides { font-size: 11pt; }
      table.cohort { font-size: 8pt; }
      .slide-wrap { padding: 16px 24px 12px; }
      .table-scroll { overflow: visible; }
      /* Prevent table rows from splitting across pages */
      table.cohort tbody tr { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
<div class="reveal">
  <div class="slides">

    <!-- ── Title slide ──────────────────────────────────────── -->
    <section>
      <div class="title-slide">
        <img class="logo" src="{{ logo_url }}" alt="Roomvu" />
        <h1>{{ deck_title }}</h1>
        <p class="subtitle">Generated {{ generated }}</p>
      </div>
    </section>

    <!-- ── Data slides ──────────────────────────────────────── -->
    {% for slide in slides %}
    <section>
      <div class="slide-wrap">
        <div class="slide-header">
          <img class="logo" src="{{ logo_url }}" alt="Roomvu" />
          <span class="report-date">{{ generated }}</span>
        </div>
        <h2>{{ slide.title }}</h2>

        {% if slide.skipped %}
        <div class="skip-notice">
          {% if slide.error is defined %}
            Data unavailable: {{ slide.error }}
          {% else %}
            Question ID not configured — add the Metabase question ID to config.yaml.
          {% endif %}
        </div>

        {% else %}
        <div class="table-scroll">
          <table class="cohort">
            <thead>
              <tr>
                <th class="col-left">Week</th>
                <th>Registrations</th>
                <th>Amount Spent</th>
                {% for wc in slide.week_cols %}
                <th>{{ wc }}</th>
                {% endfor %}
              </tr>
            </thead>
            <tbody>
              {% for row in slide.rows %}
              <tr>
                <td class="col-left">{{ row.week }}</td>
                <td>{{ row.Registration }}</td>
                <td>${{ row.Amount_Spent_display }}</td>
                {% for wc in slide.week_cols %}
                  {% set cell = row.week_cells[wc] %}
                  {% if cell.color %}
                  <td class="week-cell" style="{{ cell.color }}">{{ cell.text }}</td>
                  {% else %}
                  <td class="week-cell blank"></td>
                  {% endif %}
                {% endfor %}
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% endif %}

      </div>
    </section>
    {% endfor %}

  </div><!-- /.slides -->
</div><!-- /.reveal -->

<button id="print-btn" onclick="window.location.href=window.location.pathname+'?print-pdf#/'">⬇ Export PDF</button>

<script src="https://cdn.jsdelivr.net/npm/reveal.js@5.1.0/dist/reveal.js"></script>
<script>
  const isPrintMode = window.location.search.includes('print-pdf');
  if (isPrintMode) {
    document.getElementById('print-btn').style.display = 'none';
  }

  Reveal.initialize({
    hash: true,
    center: false,
    margin: 0.04,
    width: 1280,
    height: 720,
    transition: 'slide',
    transitionSpeed: 'fast',
    pdfMaxPagesPerSlide: 1,
    pdfSeparateFragments: false,
  });

  // Auto-trigger print dialog when loaded in ?print-pdf mode
  if (isPrintMode) {
    Reveal.addEventListener('ready', function() {
      setTimeout(function() { window.print(); }, 1000);
    });
  }
</script>
</body>
</html>
